# Neon PostgreSQL — pooled connection (for the app / Prisma Client)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Neon PostgreSQL — direct connection (for prisma db push / migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Auth.js v5 — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="your-auth-secret-here"

# Africa's Talking SMS ("sandbox" for testing)
AT_USERNAME="sandbox"
AT_API_KEY="your-africastalking-api-key"
